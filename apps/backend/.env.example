NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://codecrush:codecrush@localhost:5432/codecrush
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
DEMO_USER_PASSWORD=CodeCrushDemo123!
JWT_SECRET=dev-only-change-me-please-32-chars-min!!
JWT_EXPIRES_IN=12h
# 模型 API Key 加密主密钥（32 字节 base64）。生成：openssl rand -base64 32
MODEL_API_KEY_ENCRYPTION_KEY=REPLACE_ME_openssl_rand_base64_32_output_here
BLOB_STORE_PATH=./.data/blobs
INGESTION_EMBED_BATCH_SIZE=10
# 离线评测单用例编排超时（ms）。默认 120000——离线批跑没人在等，不套用在线熔断的 30s。
# 实测一条用例 36~46s（rewrite+intent 两次结构化调用即占 27.7s），30s 下会全部判超时。
EVAL_RUN_CASE_TIMEOUT_MS=120000
# 在线评测冷启动回看窗口（小时）。默认 24 = 017 的原行为，不设此变量的部署零变化。
# 0 = 只评此后的新问答；-1 = 回看全部历史（dailyCap 仍封顶，历史多时分多天评完）。
# ⚠️ 一次性：只在 eval_watermarks 那行**第一次被创建**时决定游标起点。行建好后改这个值
# 不会有任何效果——要重新播种必须先删那行。早于起点的 trace 永不进候选集。
ONLINE_EVAL_BACKFILL_WINDOW_HOURS=24
# 候选账本（eval_candidate_ledger）保留天数，按 trace 发生时间。默认 30 = 屏1 最长窗口。
# 该表记录游标越过的每一条 trace 及其归宿——它是游标的审计轨迹，也是与 ClickHouse 对账
# （差集 = 丢包）的依据。清理搭 worker 的周期跑，不额外建 cron。
ONLINE_EVAL_LEDGER_RETENTION_DAYS=30
# 进程角色分流（019）：api | worker | all。未设置/空 = all（单进程消费全部队列，现行为）。
# 分流部署时 API 侧设 api、评测 worker 侧设 worker；本地 pnpm dev 的 worker 进程由
# dev:worker 脚本自动设 worker，无需在 .env 里配置本项。
# PROCESS_ROLE=all
