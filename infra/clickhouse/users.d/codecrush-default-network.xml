<?xml version="1.0"?>
<!--
  Dev-only 覆盖：clickhouse-server:25.6 镜像默认把 `default` 用户限制为仅本机
  (users.d/default-user.xml: networks = ::1 / 127.0.0.1)，导致 Collector 与后端经
  Docker/主机网络连接时报 REQUIRED_PASSWORD / AUTHENTICATION_FAILED。

  这里把 default 的 networks 覆盖为 ::/0（users.d 同名元素是替换语义，实测 system.users
  只剩 ::/0），放开 Docker 内网/本机访问。配套约束：compose 将 8123/9000 只绑 127.0.0.1，
  避免无密码 default 暴露到局域网。生产/云上按 001 不变量走加密凭据 + 连接串，不用本覆盖。
-->
<clickhouse>
  <users>
    <default>
      <networks>
        <ip>::/0</ip>
      </networks>
    </default>
  </users>
</clickhouse>
