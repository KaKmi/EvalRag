<?xml version="1.0"?>
<!--
  Dev-only 覆盖：clickhouse-server:25.6 镜像默认把 `default` 用户限制为仅本机
  (users.d/default-user.xml: networks = ::1 / 127.0.0.1)，导致 Collector 与后端经
  Docker/主机网络连接时报 REQUIRED_PASSWORD / AUTHENTICATION_FAILED。

  这里把 ::/0 追加进 default 的 networks（合并而非替换），放开本地 infra 网络访问，
  保持 M0 本地开发「default / 空密码」的简单姿态。生产/云上按 001 不变量走加密凭据 +
  连接串，不使用本 dev 覆盖。
-->
<clickhouse>
  <users>
    <default>
      <networks>
        <ip>::/0</ip>
      </networks>
    </default>
  </users>
</clickhouse>
